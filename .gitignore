# Stratum — .gitignore

# ── Entorno y secretos ────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
*.cert

# ── Base de datos y memoria (datos personales) ────────────
database/memory.db
database/memory.db-wal
database/memory.db-shm
database/graph_memory.json
memory_db/
agent_files/firmware/

# ── Backups de memoria ────────────────────────────────────
stratum_backup_*.zip
stratum_pre_reset_*.zip

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.egg
MANIFEST

# ── Entornos virtuales ────────────────────────────────────
venv/
.venv/
env/
ENV/
.virtualenv/

# ── Pytest / coverage ─────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml

# ── Mypy ──────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── IDEs ──────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Node ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Archivos temporales ───────────────────────────────────
*.tmp
*.temp
.cache/
tmp/

# ── Archivos compilados de Arduino ───────────────────────
agent_files/firmware/**/*.elf
agent_files/firmware/**/*.hex
agent_files/firmware/**/*.bin
agent_files/firmware/**/*.map

# ── Excepción: mantener estructura de directorios ────────
!agent_files/.gitkeep
!database/.gitkeep
!memory_db/.gitkeep
!tools/plugins/.gitkeep

# ── Excepción: archivos de ejemplo ───────────────────────
!.env.example

.aider*
# Added by code-review-graph
.code-review-graph/
