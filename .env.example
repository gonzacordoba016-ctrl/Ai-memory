# ── LLM Provider ─────────────────────────────────────────────────────────────
# Opciones: openrouter | ollama | lmstudio
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
LLM_MODEL_FAST=openai/gpt-4o-mini
LLM_MODEL_SMART=openai/gpt-4o

# Ollama (solo si LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# ── Base de datos ─────────────────────────────────────────────────────────────
# Local: paths relativos al directorio del proyecto
# Railway: crear volumen en dashboard montado en /data, luego usar:
MEMORY_DB_PATH=./database/memory.db
# MEMORY_DB_PATH=/data/database/memory.db   ← Railway con volumen
GRAPH_DB_PATH=./database/graph_memory.json
# GRAPH_DB_PATH=/data/database/graph_memory.json   ← Railway con volumen

# ── Qdrant (vector store) ─────────────────────────────────────────────────────
# Local sin volumen: VECTOR_DB_PATH (path local, efímero en Railway)
VECTOR_DB_PATH=./memory_db
# VECTOR_DB_PATH=/data/memory_db   ← Railway con volumen
# Qdrant Cloud (recomendado para producción) → https://cloud.qdrant.io (free tier: 1GB)
# QDRANT_URL=https://xxxxxxxx.qdrant.io
# QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=agent_memory

# ── Autenticación JWT ─────────────────────────────────────────────────────────
MULTI_USER=false
JWT_SECRET=cambia-esto-en-produccion-usa-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=1440

# ── CORS (producción) ─────────────────────────────────────────────────────────
# Separar múltiples orígenes con coma
# Incluir capacitor://localhost para la app mobile
ALLOWED_ORIGINS=*

# ── Servidor ──────────────────────────────────────────────────────────────────
# Railway inyecta PORT automáticamente
PORT=8000

# ── Push Notifications (opcional — para app mobile) ──────────────────────────
# Obtener desde Firebase Console → Project Settings → Cloud Messaging → Server key
# FIREBASE_SERVER_KEY=AAAAxxxxxxxxxx...

# ── Wokwi (opcional) ─────────────────────────────────────────────────────────
# WOKWI_CLI_TOKEN=

# ── Hardware Bridge (programación remota) ─────────────────────────────────────
# Token para autenticar el bridge client que corre en tu PC
# Generá uno con: python -c "import secrets; print(secrets.token_hex(32))"
# Dejarlo vacío deshabilita la verificación (solo para desarrollo local)
BRIDGE_TOKEN=

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
